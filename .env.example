# Telegram
TG_API_ID=your_api_id
TG_API_HASH=your_api_hash
TG_PHONE=+380XXXXXXXXX
MANAGER_TG_ID=
ESCALATION_CHAT_ID=

# OpenAI
OPENAI_API_KEY=sk-...

# BAS OData
BAS_URL=https://svyou.site/UNF/odata/standard.odata
BAS_LOGIN=your_bas_login
BAS_PASSWORD=your_bas_password

# Toggle mock data (true = use mocks, false = live BAS + PG)
USE_MOCK=false

# PostgreSQL (required when USE_MOCK=false)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/svy_agent

# Sync interval in minutes (default 15)
SYNC_INTERVAL_MINUTES=15

# SQLite history DB
DB_PATH=data/history.db

# ── Multi-channel / multi-account ─────────────────────────────────────────────
# Public base URL of THIS app, used to register inbound webhooks.
#   WhatsApp/WAHA: WAHA→app can be localhost (http://localhost:8000).
#   Viber: MUST be a public HTTPS URL (use a tunnel like ngrok/cloudflared).
PUBLIC_URL=http://localhost:8000

# Fernet key to encrypt account credentials/sessions at rest in the accounts table.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, credentials are stored in PLAINTEXT (a warning is logged) — fine for dev.
ACCOUNTS_SECRET_KEY=

# Directory of files the agent/operator can send via send_file (price lists, datasheets).
DOCS_DIR=docs

# NOTE: Telegram/WhatsApp/Email/Viber ACCOUNTS are added from the dashboard
# (Налаштування → «Акаунти / Канали»), not via .env. Telegram api_id/api_hash above
# are shared by all Telegram accounts.
