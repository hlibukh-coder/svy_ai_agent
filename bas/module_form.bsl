// ============================================================================
//  Модуль керованої форми обробки "ПанельAIАгента" (розширення BAS "AIАгент")
//  Реквізит форми: HTMLПоле (Строка, необмежена) — прив'язаний до елемента
//  "Поле HTML документа". Мова — стандартні (російські) ключові слова 1С.
// ============================================================================

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	URL = ПолучитьАдресПанели();

	// Вбудовуємо панель через iframe у HTML-поле (потрібен WebView2 / платформа 8.3.21+)
	HTMLПоле =
		"<!DOCTYPE html>"
		+ "<html><head><meta charset=""utf-8"">"
		+ "<meta name=""viewport"" content=""width=device-width, initial-scale=1""></head>"
		+ "<body style=""margin:0;padding:0;overflow:hidden;height:100vh"">"
		+ "<iframe src=""" + URL + """ "
		+ "style=""border:0;width:100%;height:100vh;display:block""></iframe>"
		+ "</body></html>";

КонецПроцедуры

// Адреса панелі береться з константи розширення; якщо порожня — значення за замовчуванням.
&НаСервереБезКонтекста
Функция ПолучитьАдресПанели()
	URL = "";
	Попытка
		URL = Константы.АдресПанелиAI.Получить();
	Исключение
		URL = "";
	КонецПопытки;
	Если ПустаяСтрока(URL) Тогда
		URL = "http://localhost:8000/dashboard";
	КонецЕсли;
	Возврат СокрЛП(URL);
КонецФункции

// ── Фолбек: відкрити панель у системному браузері (працює на будь-якій платформі) ──
// Додай на форму команду "ВідкритиУБраузері" і кнопку, що її викликає.
&НаКлиенте
Процедура ВидкрытиУБраузери(Команда)
	URL = ПолучитьАдресПанели();
	НачатьЗапускПриложения(Новый ОписаниеОповещения, URL);
КонецПроцедуры

// (необов'язково) кнопка "Оновити" — перезавантажити вбудовану панель
&НаКлиенте
Процедура ОновитиПанель(Команда)
	URL = ПолучитьАдресПанели();
	HTMLПоле =
		"<!DOCTYPE html><html><head><meta charset=""utf-8""></head>"
		+ "<body style=""margin:0;overflow:hidden;height:100vh"">"
		+ "<iframe src=""" + URL + "?t=" + Строка(ТекущаяДата()) + """ "
		+ "style=""border:0;width:100%;height:100vh""></iframe></body></html>";
КонецПроцедуры
